{
  "name": "bazaarlens",
  "version": "0.1.0",
  "private": true,
  "description": "BazaarLens: browser-native shopping copilot for Indian commerce.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @bazaarlens/api --filter @bazaarlens/web --filter @bazaarlens/extension dev",
    "build": "pnpm --filter @bazaarlens/shared build && pnpm --filter @bazaarlens/agent build && pnpm --filter @bazaarlens/api build && pnpm --filter @bazaarlens/web build && pnpm --filter @bazaarlens/extension build",
    "typecheck": "pnpm --filter @bazaarlens/shared typecheck && pnpm --filter @bazaarlens/agent typecheck && pnpm --filter @bazaarlens/api typecheck && pnpm --filter @bazaarlens/web typecheck && pnpm --filter @bazaarlens/extension typecheck",
    "test": "pnpm test:scripts && pnpm --filter @bazaarlens/shared test && pnpm --filter @bazaarlens/agent test && pnpm --filter @bazaarlens/api test && pnpm --filter @bazaarlens/extension test",
    "test:scripts": "vitest run scripts/*.test.mjs",
    "verify": "pnpm prisma:generate && pnpm test && pnpm submission:check && pnpm typecheck && pnpm build && pnpm extension:validate",
    "smoke:docker": "node scripts/smoke-docker.mjs",
    "smoke:a2a": "node scripts/smoke-a2a.mjs",
    "smoke:dev:web": "node scripts/smoke-dev-web.mjs",
    "smoke:web": "node scripts/smoke-web.mjs",
    "smoke:live:web": "node scripts/smoke-live-web.mjs",
    "smoke:sites": "node scripts/smoke-live-sites.mjs",
    "submission:check": "node scripts/check-submission-artifacts.mjs",
    "submission:check:final": "node scripts/check-submission-artifacts.mjs --final",
    "extension:icons": "node scripts/generate-extension-icons.mjs",
    "extension:validate": "node scripts/validate-extension.mjs",
    "extension:package:validate": "EXTENSION_OUTPUT_DIR=artifacts/chrome-mv3 EXTENSION_VALIDATE_ZIP=1 node scripts/validate-extension.mjs",
    "extension:store:validate": "EXTENSION_STORE_BUILD=1 node scripts/validate-extension.mjs",
    "extension:store:package:validate": "EXTENSION_STORE_BUILD=1 EXTENSION_OUTPUT_DIR=artifacts/chrome-mv3 EXTENSION_VALIDATE_ZIP=1 node scripts/validate-extension.mjs",
    "live:check": "node scripts/live-readiness.mjs",
    "live:check:google": "node scripts/live-readiness.mjs --require-google",
    "prod:check": "pnpm --filter @bazaarlens/api build && node scripts/check-production-env.mjs",
    "prod:check:google": "pnpm --filter @bazaarlens/api build && node scripts/check-production-env.mjs --require-google",
    "prod:caddy:validate": "node scripts/validate-caddy.mjs",
    "lint": "pnpm --recursive --if-present lint",
    "docker:up": "docker compose up -d --build --remove-orphans",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:dev:ps": "docker compose -f docker-compose.dev.yml ps",
    "docker:dev:extension": "docker compose -f docker-compose.dev.yml --profile extension up extension",
    "docker:dev:migrate": "docker compose -f docker-compose.dev.yml exec api pnpm --filter @bazaarlens/api prisma:migrate",
    "docker:extension": "docker compose --profile extension run --build --rm extension-builder",
    "docker:prod:config": "docker compose --env-file ${BAZAARLENS_ENV_FILE:-deploy/production.env} -f docker-compose.prod.yml config --quiet",
    "docker:logs": "docker compose logs -f",
    "deploy:server-images": "node scripts/deploy-server-images.mjs",
    "deploy:cloudflare:check": "node scripts/verify-cloudflare-dns.mjs",
    "deploy:google-oauth": "node scripts/configure-google-oauth.mjs",
    "db:migrate": "pnpm --filter @bazaarlens/api prisma:migrate",
    "db:generate": "pnpm --filter @bazaarlens/api prisma:generate",
    "prisma:generate": "pnpm --filter @bazaarlens/api prisma:generate"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}
