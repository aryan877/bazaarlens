NODE_ENV=production

# Public API and browser origins
APP_DOMAIN=bazaarlens.example
API_DOMAIN=api.bazaarlens.example
ACME_EMAIL=ops@bazaarlens.example
API_PUBLIC_URL=https://api.bazaarlens.example
CORS_ORIGIN=https://bazaarlens.example

# API secrets and providers
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=14d
# Optional; leave empty to disable the Google button until OAuth is configured.
# When enabled, this must match VITE_GOOGLE_CLIENT_ID below.
GOOGLE_CLIENT_ID=
A2A_AGENT_KEY=replace-with-32-plus-character-a2a-agent-key
A2A_AGENT_USER_EMAIL=a2a-agent@bazaarlens.app
GOOGLE_VERTEX_API_KEY=
GOOGLE_VERTEX_PROJECT=replace-with-google-cloud-project-id
GOOGLE_CLOUD_PROJECT=
# For service-account ADC, put the JSON in GOOGLE_APPLICATION_CREDENTIALS_HOST_DIR
# and point this container path at it, for example:
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/bazaarlens/google-application-credentials.json
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_HOST_DIR=./deploy/secrets
GOOGLE_VERTEX_LOCATION=global
GOOGLE_VERTEX_MODEL=gemini-3.5-flash
HACKATHON_TRACK=mongodb
# Empty means selected track only. Use all only when every enabled non-Mongo MCP evidence provider is fully configured.
AGENT_EVIDENCE_PROVIDERS=
TRUST_PROXY_HOPS=1
RATE_LIMIT_DEFAULT_TTL_SECONDS=60
RATE_LIMIT_DEFAULT_LIMIT=300
RATE_LIMIT_AUTH_TTL_SECONDS=60
RATE_LIMIT_AUTH_LIMIT=30
RATE_LIMIT_AGENT_ANALYZE_TTL_SECONDS=60
RATE_LIMIT_AGENT_ANALYZE_LIMIT=20
RATE_LIMIT_AGENT_APPROVAL_TTL_SECONDS=60
RATE_LIMIT_AGENT_APPROVAL_LIMIT=60

# Postgres
POSTGRES_USER=bazaarlens
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=bazaarlens
DATABASE_URL=postgresql://bazaarlens:replace-with-strong-postgres-password@postgres:5432/bazaarlens?schema=public

# Agent memory. Prefer a remote MongoDB/Atlas connection on the 1GB VPS.
AGENT_MEMORY_ENABLED=true
AGENT_MEMORY_BACKEND=mongodb
AGENT_MEMORY_MCP_HTTP_URL=
AGENT_MEMORY_MCP_COMMAND=
AGENT_MEMORY_MCP_ARGS=
MONGODB_MEMORY_CONNECTION_STRING=mongodb+srv://replace-with-mongodb-atlas-connection-string
MONGODB_MEMORY_DATABASE=bazaarlens_agent
MONGODB_MEMORY_COLLECTION=product_memory

# Optional MCP capability checks. Keep disabled unless credentials are configured.
MCP_READINESS_CHECKS_ENABLED=false
MCP_READINESS_TIMEOUT_MS=5000
ELASTIC_MCP_ENABLED=false
ELASTIC_MCP_HTTP_URL=
ELASTIC_MCP_COMMAND=
ELASTIC_MCP_ARGS=
ELASTIC_KIBANA_URL=
ELASTIC_KIBANA_SPACE=
ELASTIC_API_KEY=
ELASTIC_PRODUCT_INDEX=
ELASTIC_PRODUCT_SEARCH_TOOL=
ELASTIC_PRODUCT_SOURCE_FIELDS=title,merchant,priceRaw,url,seller,rating,reviewCount,availability,checkedAt
ES_URL=
ES_API_KEY=
ES_USERNAME=
ES_PASSWORD=
ES_SSL_SKIP_VERIFY=false
ARIZE_MCP_ENABLED=false
ARIZE_MCP_COMMAND=npx
ARIZE_MCP_ARGS=
FIVETRAN_MCP_ENABLED=false
FIVETRAN_MCP_COMMAND=uvx
FIVETRAN_MCP_ARGS=
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_ALLOW_WRITES=false
GITLAB_MCP_ENABLED=false
GITLAB_MCP_HTTP_URL=
GITLAB_MCP_COMMAND=
GITLAB_MCP_ARGS=
GITLAB_MCP_AUTH_READY=false
GITLAB_PROJECT_ID=
DYNATRACE_MCP_ENABLED=false
DYNATRACE_MCP_HTTP_URL=
DYNATRACE_ENVIRONMENT_URL=
DYNATRACE_API_TOKEN=
PHOENIX_TRACING_ENABLED=false
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_HOST=
PHOENIX_API_KEY=
PHOENIX_PROJECT=

# Public Caddy host ports
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443

# Client build-time API/OAuth values
VITE_API_URL=https://api.bazaarlens.example
# Public browser Google client ID. Must match GOOGLE_CLIENT_ID when Google auth is enabled.
VITE_GOOGLE_CLIENT_ID=
WXT_API_URL=https://api.bazaarlens.example
