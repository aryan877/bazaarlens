{
  "name": "@bazaarlens/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "pnpm --filter @bazaarlens/shared build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "^4.0.142",
    "@bazaarlens/shared": "workspace:*",
    "ai": "^6.0.198",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  }
}
