{
  "name": "@bazaarlens/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "rm -rf dist && nest build",
    "start": "node dist/main.js",
    "typecheck": "pnpm --filter @bazaarlens/shared build && pnpm --filter @bazaarlens/agent build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@arizeai/phoenix-otel": "^1.0.2",
    "@bazaarlens/agent": "workspace:*",
    "@bazaarlens/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "express": "5.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "prisma": "^6.19.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.8"
  }
}
